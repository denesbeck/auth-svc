# Required — generate a real secret: openssl rand -base64 48
JWT_SECRET=

# Optional (defaults shown)
PORT=4001
NODE_ENV=development
DEBUG=false
ISSUER_URL=http://localhost:4001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/auth_dev
DATABASE_SSL=false
REDIS_URL=redis://localhost:6379

# Required in production — comma-separated allowed origins
# Example: CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=
